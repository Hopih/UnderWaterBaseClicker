<Window x:Class="UnderwaterBaseClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:UnderwaterBaseClicker.Ui"
        Title="Подводная база — кликер"
        Width="1100" Height="720"
        MinWidth="960" MinHeight="620"
        Background="{StaticResource OceanBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Игровая зона -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HUD как в мобильных кликерах -->
                <Border Grid.Row="0" Background="{StaticResource HudGradientBrush}"
                        Padding="20,16" BorderBrush="#3300D4E8" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⚡ ЭНЕРГИЯ" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EnergyText" Margin="0,4,0,0"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="EnergyPulse" ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FFFFD54F" BlurRadius="16" ShadowDepth="0" Opacity="0.7"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border Background="#44000000" CornerRadius="12" Padding="10,6">
                                <StackPanel>
                                    <TextBlock x:Name="RatesText" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}" TextAlignment="Right"/>
                                    <TextBlock x:Name="StatsText" FontSize="10" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextMutedBrush}" TextAlignment="Right"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <ui:UnderwaterBaseView x:Name="BaseView"/>
                    <Canvas x:Name="FxCanvas" IsHitTestVisible="False"/>
                </Grid>

                <TextBlock Grid.Row="2" x:Name="BaseHintText"
                           TextAlignment="Center" Margin="0,0,0,10"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
            </Grid>

            <!-- Магазин -->
            <Border Grid.Column="1" Background="{StaticResource ShopPanelBrush}"
                    BorderBrush="#5500D4E8" BorderThickness="1,0,0,0">
                <DockPanel Margin="14,12">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="🏗️ МАГАЗИН МОДУЛЕЙ"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Покупай — строй базу!"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="UpgradesPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
