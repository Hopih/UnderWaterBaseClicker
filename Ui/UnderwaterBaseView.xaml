<UserControl x:Class="UnderwaterBaseClicker.Ui.UnderwaterBaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="True">
    <Grid>
        <Rectangle Fill="#FF1A4A6E"/>

        <Viewbox Stretch="Uniform" Margin="8,4">
            <Canvas x:Name="Scene" Width="640" Height="480">

                <!-- Вода -->
                <Rectangle Width="640" Height="480" Panel.ZIndex="0">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF3A7A9E" Offset="0"/>
                            <GradientStop Color="#FF245E82" Offset="0.45"/>
                            <GradientStop Color="#FF1A4A6E" Offset="0.75"/>
                            <GradientStop Color="#FF153D5C" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Лёгкие лучи света сверху -->
                <Rectangle Width="640" Height="220" Panel.ZIndex="0" Opacity="0.18">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Песок (компактнее) -->
                <Rectangle Canvas.Top="410" Width="640" Height="70" Panel.ZIndex="1">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFE8D4A8" Offset="0"/>
                            <GradientStop Color="#FFD4B87A" Offset="0.4"/>
                            <GradientStop Color="#FFC4A060" Offset="0.75"/>
                            <GradientStop Color="#FFA88848" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Rectangle Canvas.Top="406" Width="640" Height="6" Panel.ZIndex="2" Opacity="0.4">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#99FFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Rectangle Canvas.Top="418" Width="640" Height="58" Panel.ZIndex="2" Opacity="0.1">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF8B6914" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#FF6B4E10" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Камни на песке -->
                <Canvas x:Name="SandDecorLayer" Canvas.Top="410" Panel.ZIndex="3"/>

                <!-- Подлодки в воде -->
                <Canvas x:Name="DockSlot" Canvas.Left="140" Canvas.Top="248" Panel.ZIndex="6"/>

                <!-- Дроны-разведчики -->
                <Canvas x:Name="DroneLayer" Panel.ZIndex="7" IsHitTestVisible="False"/>

                <!-- Водоросли на песке -->
                <Canvas x:Name="AlgaeLayer" Canvas.Left="12" Canvas.Top="352" Panel.ZIndex="5"/>

                <Button x:Name="ReactorButton"
                        Canvas.Left="270" Canvas.Top="120"
                        Width="100" Height="100"
                        Panel.ZIndex="8"
                        Cursor="Hand"
                        Click="ReactorButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Width="96" Height="96"
                                         Stroke="#9900E5FF" StrokeThickness="2" Opacity="0.7"/>
                                <TextBlock Text="ТАП!" FontSize="15" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="ReactorScale" ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.RenderTransformOrigin>
                        <Point X="0.5" Y="0.5"/>
                    </Button.RenderTransformOrigin>
                </Button>
            </Canvas>
        </Viewbox>

        <Canvas x:Name="BubbleCanvas" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
